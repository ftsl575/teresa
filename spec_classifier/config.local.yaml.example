# config.local.yaml — Personal overrides (NOT committed to git).
# Copy to config.local.yaml and edit paths for your machine.
# These override values from config.yaml.
# CLI arguments (--output-dir, --input, --batch-dir) override everything.

paths:
  input_root: "C:\\Users\\<USERNAME>\\Desktop\\INPUT"
  output_root: "C:\\Users\\<USERNAME>\\Desktop\\OUTPUT"

# Where to redirect temporary files (.pytest_cache, __pycache__).
# Used by scripts/clean.ps1, run.ps1, and teresa_gui.py.
temp_root: "C:\\Users\\<USERNAME>\\Desktop\\temporary"
